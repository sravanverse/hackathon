# =============================================================================
# NitroStack Local Development Environment Configuration (SSE/HTTP Transport)
# =============================================================================

# System Mode
# -----------
NODE_ENV=development

# Logging Configuration
# ---------------------
NITRO_LOG_LEVEL=info

# Protocol Conventions
# --------------------
NITROSTACK_APP_MODE=universal

# Server Transport Settings
# -------------------------
# Set to 'http' to run a pure HTTP server with SSE (Server-Sent Events) endpoints.
# Set to 'dual' to run both STDIO and HTTP/SSE transports concurrently.
# Avoid using 'sse' directly, as it defaults back to 'stdio'.
MCP_TRANSPORT_TYPE=http

# HTTP Listener Config
PORT=3000
HOST=localhost
ENABLE_CORS=true

# Session Management Limits
# -------------------------
MCP_MAX_SESSIONS=10
MCP_SESSION_TIMEOUT_MS=600000

# Mapbox Widget Integration (Optional)
# ------------------------------------
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here
